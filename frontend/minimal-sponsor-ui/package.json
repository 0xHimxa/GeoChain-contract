{
  "name": "minimal-sponsor-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot server.ts",
    "frontend:dev": "bunx vite --host --port 5174",
    "frontend:build": "bunx vite build",
    "frontend:preview": "bunx vite preview --host --port 4174",
    "check": "tsc --noEmit",
    "dev:agent": "bun --hot server-agent.ts",
    "frontend:dev:agent": "bunx vite --config vite.agent.config.ts --open /agent.html",
    "frontend:preview:agent": "bunx vite preview --config vite.agent.config.ts"
  },
  "dependencies": {
    "ethers": "^6.15.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^7.2.0"
  }
}
