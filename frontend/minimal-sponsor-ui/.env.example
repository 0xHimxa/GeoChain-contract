# CRE policy trigger endpoint (deployed workflow HTTP trigger URL)
CRE_TRIGGER_URL=https://YOUR_CRE_HTTP_TRIGGER_URL

# ERC-4337 infrastructure
# Example Pimlico format:
#   https://api.pimlico.io/v2/base-sepolia/rpc?apikey=YOUR_API_KEY
# You can use the same endpoint for AA_BUNDLER_URL and AA_PAYMASTER_URL on Pimlico.
AA_CHAIN=baseSepolia
AA_RPC_URL=https://YOUR_CHAIN_RPC_URL
AA_BUNDLER_URL=https://YOUR_BUNDLER_RPC_URL
AA_PAYMASTER_URL=https://YOUR_PAYMASTER_RPC_URL

# EntryPoint v0.7 on most public testnets/mainnets
AA_ENTRYPOINT=0x0000000071727de22e5e9d8baf0edac6f37da032

# Owner key for the SimpleAccount used in the test script
AA_OWNER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional destination for the demo sponsored tx. Defaults to sender smart-account address.
AA_TEST_TO=0x0000000000000000000000000000000000000000
