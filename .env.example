# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# Private key for deployment (without 0x prefix)
PRIVATE_KEY=

# RPC URLs for different networks
MAINNET_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/YOUR_API_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
GOERLI_RPC_URL=https://eth-goerli.alchemyapi.io/v2/YOUR_API_KEY
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# Etherscan API keys for contract verification
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=

# Collateral token address (USDC or other ERC20)
# Mainnet USDC: 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
# Sepolia USDC: 0x... (deploy your own or use testnet USDC)
COLLATERAL_TOKEN_ADDRESS=

# Optional: For testing
ANVIL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
